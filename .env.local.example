# Supabase — Settings > API in the Supabase Studio dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key: bypasses RLS. Server-only, never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# TossPayments — https://developers.tosspayments.com dashboard
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# Vercel Cron auth — random secret; Vercel sends it as
# `Authorization: Bearer $CRON_SECRET` automatically for scheduled routes.
CRON_SECRET=

# Kakao-login accounts that should see admin mode (comma-separated emails).
ADMIN_EMAILS=
